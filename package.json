{
  "name": "n8n-nodes-layerzero",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for LayerZero omnichain interoperability protocol providing 16 resources and 90+ operations for cross-chain messaging, OFT/ONFT transfers, DVN configuration, and protocol analytics.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-layerzero.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-layerzero#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-layerzero/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "layerzero",
    "omnichain",
    "cross-chain",
    "interoperability",
    "blockchain",
    "web3",
    "oft",
    "onft",
    "dvn",
    "messaging",
    "defi",
    "ethereum",
    "arbitrum",
    "optimism",
    "polygon",
    "avalanche",
    "bnb-chain",
    "solana",
    "multichain"
  ],
  "main": "dist/nodes/LayerZero/LayerZero.node.js",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/LayerZeroApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/LayerZero/LayerZero.node.js",
      "dist/nodes/LayerZero/LayerZeroTrigger.node.js"
    ]
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc && gulp build:icons",
    "build:noicons": "tsc",
    "dev": "tsc --watch",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ethers": "^6.9.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}